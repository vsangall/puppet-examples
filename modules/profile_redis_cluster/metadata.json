{
  "name": "example-profile_redis_cluster",
  "version": "3.1.0",
  "author": "Platform Team",
  "summary": "Redis profile using puppet-redis with PuppetDB node discovery",
  "license": "Apache-2.0",
  "source": "https://github.com/example-org/puppet-profile_redis_cluster",
  "dependencies": [
    { "name": "puppetlabs-stdlib", "version_requirement": ">= 9.0.0 < 10.0.0" },
    { "name": "puppet-redis", "version_requirement": ">= 11.0.0 < 12.0.0" }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "Ubuntu",
      "operatingsystemrelease": ["24.04"]
    }
  ],
  "requirements": [
    { "name": "puppet", "version_requirement": ">= 7.0.0 < 9.0.0" }
  ],
  "tags": ["redis", "puppetdb"]
}
